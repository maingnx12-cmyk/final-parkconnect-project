<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>ParkConnect</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --blue:#1A56DB;--blue2:#1445B8;--blue3:#0F3490;--blue4:#4D82FF;
  --blue-lt:#EEF4FF;--blue-b:#B3CCFF;--blue-ln:#D9E5FF;--sky:#0EA5E9;
  --green:#10B981;--gl:#D1FAE5;--gd:#065F46;
  --amber:#F59E0B;--aml:#FEF3C7;--amd:#92400E;
  --red:#EF4444;--rl:#FEE2E2;--rd:#991B1B;
  --pu:#8B5CF6;--pul:#EDE9FE;--pud:#5B21B6;
  --gold:#F59E0B;--gold-lt:#FEF3C7;
  --g0:#F8FAFC;--g1:#F1F5F9;--g2:#E2E8F0;--g3:#CBD5E1;
  --g4:#94A3B8;--g5:#64748B;--g6:#475569;--g7:#334155;
  --g8:#1E293B;--g9:#0F172A;--wh:#fff;
  --F:'Plus Jakarta Sans',sans-serif;
  --r1:8px;--r2:12px;--r3:16px;--r4:20px;
  --s1:0 1px 3px rgba(0,0,0,.06),0 1px 2px rgba(0,0,0,.04);
  --s2:0 4px 16px rgba(0,0,0,.08);--s3:0 12px 32px rgba(0,0,0,.12);
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth}
body{font-family:var(--F);background:var(--g0);color:var(--g8);font-size:15px;line-height:1.5;max-width:430px;margin:0 auto;min-height:100vh;overflow-x:hidden}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
@keyframes pop{from{transform:scale(0);opacity:0}to{transform:scale(1);opacity:1}}
@keyframes up{from{transform:translateY(100%)}to{transform:translateY(0)}}
@keyframes fIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.screen{display:none;flex-direction:column;min-height:100dvh}.screen.on{display:flex}
.sb{height:44px;background:var(--wh);display:flex;align-items:center;justify-content:space-between;padding:8px 20px 0;flex-shrink:0;position:sticky;top:0;z-index:100}
.sb.dk{background:var(--blue3)}.sb.tr{background:transparent;position:absolute;width:100%;z-index:10}
.sb-t{font-size:15px;font-weight:700;color:var(--g9)}.sb.dk .sb-t,.sb.tr .sb-t{color:#fff}
.sb-i{font-size:12px;color:var(--g5);display:flex;gap:6px}.sb.dk .sb-i,.sb.tr .sb-i{color:rgba(255,255,255,.8)}
.tb{background:var(--wh);padding:12px 20px 14px;border-bottom:1px solid var(--g1);flex-shrink:0;position:sticky;top:44px;z-index:99}
.tb-r{display:flex;align-items:center;gap:12px}
.tb-t{font-size:18px;font-weight:800;color:var(--g9);flex:1}.tb-s{font-size:13px;color:var(--g5);margin-top:2px}
.ib,.bk{width:40px;height:40px;border-radius:var(--r2);background:var(--g1);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--g7);flex-shrink:0}
.ib:active,.bk:active{background:var(--g2)}
.sc{flex:1;overflow-y:auto;overflow-x:hidden;padding-bottom:90px}.sc::-webkit-scrollbar{display:none}
.bn{position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;background:var(--wh);border-top:1px solid var(--g2);display:flex;padding:8px 0 max(8px,env(safe-area-inset-bottom));z-index:200;box-shadow:0 -4px 20px rgba(0,0,0,.06)}
.bt{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;padding:2px 0;cursor:pointer;border:none;background:transparent}
.bt-i{font-size:22px;line-height:1}.bt-l{font-size:10px;font-weight:600;color:var(--g4)}.bt.on .bt-l{color:var(--blue)}
.bt-d{width:4px;height:4px;border-radius:50%;background:transparent;margin-top:1px}.bt.on .bt-d{background:var(--blue)}
.cw{position:fixed;bottom:72px;left:50%;transform:translateX(-50%);width:calc(100% - 32px);max-width:398px;z-index:150}
.cta{width:100%;padding:16px;border-radius:var(--r3);border:none;background:var(--blue);color:#fff;font-family:var(--F);font-size:16px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 8px 24px rgba(26,86,219,.35)}
.cta:active{transform:scale(.98)}.cta.gr{background:var(--green);box-shadow:0 8px 24px rgba(16,185,129,.3)}
.sl{font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--g4);margin-bottom:14px}
.sdiv{height:8px;background:var(--g1);margin:20px -20px}.secb{padding:16px 20px 0}
.tag{font-size:11px;font-weight:600;padding:3px 9px;border-radius:100px}
.t-g{background:var(--gl);color:var(--gd)}.t-a{background:var(--aml);color:var(--amd)}
.t-r{background:var(--rl);color:var(--rd)}.t-b{background:var(--blue-lt);color:var(--blue2)}.t-s{background:var(--g1);color:var(--g6)}
.pill{display:flex;align-items:center;gap:5px;background:var(--g1);border-radius:100px;padding:6px 12px;font-size:12px;font-weight:600;color:var(--g7)}
.pill.ac{background:var(--blue-lt);color:var(--blue2)}.pill.gn{background:var(--gl);color:var(--gd)}
/* WELCOME */
.w-hero{background:linear-gradient(160deg,var(--blue3),var(--blue) 55%,var(--sky));padding:60px 28px 40px;display:flex;flex-direction:column;align-items:center;text-align:center;flex:1;position:relative;overflow:hidden}
.w-logo{width:72px;height:72px;border-radius:20px;background:rgba(255,255,255,.18);border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-size:36px;margin-bottom:24px;animation:pop .5s cubic-bezier(.34,1.56,.64,1)}
.w-title{font-size:32px;font-weight:800;color:#fff;margin-bottom:10px}
.w-sub{font-size:15px;color:rgba(255,255,255,.8);line-height:1.6}
.role-wrap{padding:0 20px 20px;background:var(--wh);display:flex;flex-direction:column;gap:12px}
.role-lbl{padding:20px 0 8px;font-size:14px;font-weight:600;color:var(--g5);text-align:center}
.rc{display:flex;align-items:center;gap:16px;padding:18px 16px;background:var(--wh);border:2px solid var(--g2);border-radius:var(--r4);cursor:pointer;transition:all .2s}
.rc:active{transform:scale(.98)}
.rc.u:active,.rc.u:hover{border-color:var(--blue);background:var(--blue-lt)}
.rc.o:active,.rc.o:hover{border-color:var(--green);background:var(--gl)}
.rc-ico{width:56px;height:56px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0}
.rc-ico.bl{background:var(--blue-lt)}.rc-ico.gn{background:var(--gl)}
.rc-ttl{font-size:16px;font-weight:800;color:var(--g9);margin-bottom:3px}
.rc-desc{font-size:13px;color:var(--g5);line-height:1.4}
.rc-arr{font-size:20px;color:var(--g4)}
.w-foot{padding:16px 20px;text-align:center;font-size:12px;color:var(--g4);background:var(--wh)}
/* LOGIN */
.lh{background:linear-gradient(150deg,var(--blue3),var(--blue));padding:48px 24px 32px;text-align:center;flex-shrink:0}
.lh-ico{width:60px;height:60px;border-radius:18px;background:rgba(255,255,255,.18);border:2px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 16px}
.lh-t{font-size:24px;font-weight:800;color:#fff;margin-bottom:6px}.lh-s{font-size:14px;color:rgba(255,255,255,.8)}
.lbody{flex:1;padding:24px 20px;background:var(--wh)}
.ll{font-size:13px;font-weight:700;color:var(--g7);margin-bottom:8px;display:block}
.li{width:100%;background:var(--g0);border:1.5px solid var(--g2);border-radius:var(--r2);padding:13px 16px;font-family:var(--F);font-size:16px;color:var(--g9);outline:none;margin-bottom:14px}
.li:focus{border-color:var(--blue4);background:var(--wh)}.li::placeholder{color:var(--g4)}
.l-phone{display:flex;gap:8px;margin-bottom:14px}
.l-flag{background:var(--g0);border:1.5px solid var(--g2);border-radius:var(--r2);padding:13px 12px;font-size:14px;font-weight:600;color:var(--g7);white-space:nowrap;flex-shrink:0}
.otp-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.otp-b{background:var(--g0);border:1.5px solid var(--g2);border-radius:var(--r2);padding:14px 4px;text-align:center;font-size:22px;font-weight:800;color:var(--g9);outline:none;font-family:var(--F)}
.otp-b:focus{border-color:var(--blue);background:var(--wh)}
.l-btn{width:100%;padding:15px;border-radius:var(--r2);border:none;background:var(--blue);color:#fff;font-family:var(--F);font-size:16px;font-weight:700;cursor:pointer;box-shadow:0 6px 20px rgba(26,86,219,.3);margin-bottom:12px}
.l-btn:active{transform:scale(.98)}.l-btn.gr{background:var(--green)}
.l-or{text-align:center;font-size:13px;color:var(--g4);margin:4px 0 12px;position:relative}
.l-or::before,.l-or::after{content:'';position:absolute;top:50%;width:38%;height:1px;background:var(--g2)}
.l-or::before{left:0}.l-or::after{right:0}
.l-alt{width:100%;padding:13px;border-radius:var(--r2);border:1.5px solid var(--g2);background:var(--wh);font-family:var(--F);font-size:15px;font-weight:600;color:var(--g7);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px}
.l-back{width:100%;padding:13px;border-radius:var(--r2);border:1.5px solid var(--g2);background:transparent;color:var(--g6);font-family:var(--F);font-size:14px;font-weight:600;cursor:pointer;margin-top:8px}
/* HOME */
.hero{background:linear-gradient(160deg,var(--blue3),var(--blue) 60%,var(--sky));padding:20px 20px 28px}
.hero-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.logo{display:flex;align-items:center;gap:8px}
.logo-b{width:34px;height:34px;border-radius:10px;background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.3);display:flex;align-items:center;justify-content:center;font-size:17px}
.logo-n{font-size:18px;font-weight:800;color:#fff}.logo-n em{font-style:normal;color:rgba(255,255,255,.7)}
.notif{width:40px;height:40px;border-radius:var(--r2);background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);display:flex;align-items:center;justify-content:center;font-size:18px;cursor:pointer;position:relative}
.n-dot{position:absolute;top:8px;right:8px;width:8px;height:8px;border-radius:50%;background:var(--red)}
.hero-hi{font-size:13px;color:rgba(255,255,255,.75);margin-bottom:3px}
.hero-nm{font-size:20px;font-weight:800;color:#fff;margin-bottom:16px}.hero-nm em{font-style:normal;color:#0FF5A0}
.sbar2{background:#fff;border-radius:var(--r3);display:flex;align-items:center;gap:10px;padding:10px 14px;box-shadow:0 8px 24px rgba(0,0,0,.2)}
.sbar2 input{flex:1;border:none;outline:none;font-family:var(--F);font-size:15px;color:var(--g8);background:transparent}.sbar2 input::placeholder{color:var(--g4)}
.sg{width:36px;height:36px;border-radius:var(--r1);background:var(--blue);border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0}
.qa-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;padding:16px 20px}
.qa{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer}
.qa-i{width:52px;height:52px;border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:22px}
.qa-l{font-size:11px;font-weight:600;color:var(--g6);text-align:center;line-height:1.3}
.vsc{display:flex;gap:10px;overflow-x:auto;margin:0 -20px;padding:0 20px 4px}.vsc::-webkit-scrollbar{display:none}
.vi{display:flex;flex-direction:column;align-items:center;gap:6px;cursor:pointer;flex-shrink:0;padding:4px;border-radius:var(--r4);min-width:72px}
.vi-b{width:64px;height:64px;border-radius:18px;background:var(--g1);display:flex;align-items:center;justify-content:center;font-size:28px;border:2.5px solid transparent}
.vi-n{font-size:12px;font-weight:600;color:var(--g5)}
.vi.sel .vi-b{background:var(--blue-lt);border-color:var(--blue4);box-shadow:0 0 0 4px rgba(26,86,219,.1)}.vi.sel .vi-n{color:var(--blue)}
.csc{display:flex;gap:8px;overflow-x:auto;padding:0 20px 4px;margin:14px -20px 0}.csc::-webkit-scrollbar{display:none}
.chip{flex-shrink:0;padding:7px 14px;border-radius:100px;border:1.5px solid var(--g2);color:var(--g6);font-size:13px;font-weight:600;cursor:pointer;background:#fff;white-space:nowrap}
.chip:active{background:var(--g1)}.chip.sel{background:var(--blue);border-color:var(--blue);color:#fff}
.stats{display:grid;grid-template-columns:repeat(4,1fr);background:#fff;border-radius:var(--r3);margin:16px 20px 0;box-shadow:var(--s1);border:1px solid var(--g2);overflow:hidden}
.sb2{padding:12px 8px;text-align:center;border-right:1px solid var(--g1)}.sb2:last-child{border-right:none}
.sn{font-size:16px;font-weight:800;color:var(--blue)}.sl2{font-size:10px;font-weight:600;color:var(--g4);margin-top:1px;line-height:1.3}
.lmr{display:flex;align-items:center;justify-content:space-between;padding:16px 20px 10px}
.rcc{font-size:14px;font-weight:600;color:var(--g6)}
.lmt{display:flex;background:var(--g1);border-radius:10px;padding:3px;gap:2px}
.lmb{padding:6px 14px;border-radius:8px;border:none;font-family:var(--F);font-size:13px;font-weight:600;color:var(--g4);background:transparent;cursor:pointer}
.lmb.on{background:#fff;color:var(--blue);box-shadow:var(--s1)}
.pcards{display:flex;flex-direction:column;padding:0 16px}
.pcard{background:#fff;border-radius:var(--r3);border:1.5px solid var(--g2);padding:14px;margin-bottom:10px;display:flex;gap:12px;cursor:pointer;box-shadow:var(--s1)}
.pcard:active{background:var(--blue-lt);border-color:var(--blue4);transform:scale(.99)}
.pthumb{width:72px;height:72px;border-radius:var(--r2);background:var(--blue-lt);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:28px}
.pbody{flex:1;min-width:0}.pname{font-size:15px;font-weight:700;color:var(--g9);margin-bottom:2px;line-height:1.3}
.paddr{font-size:12px;color:var(--g4);margin-bottom:8px}.ptags{display:flex;gap:5px;flex-wrap:wrap}
.pr{text-align:right;flex-shrink:0}.pprice{font-size:16px;font-weight:800;color:var(--g9)}.pprice span{font-size:11px;font-weight:400;color:var(--g4)}
.pstar{font-size:12px;color:var(--g5);margin-top:3px}.pstar em{font-style:normal;color:var(--amber)}
.ob{width:64px;height:4px;background:var(--g2);border-radius:2px;margin:6px 0 2px auto;overflow:hidden}.of{height:100%;border-radius:2px}.ot{font-size:11px;color:var(--g4)}
.mapwrap{margin:0 16px 10px;background:#fff;border:1.5px solid var(--g2);border-radius:var(--r4);height:360px;position:relative;overflow:hidden;box-shadow:var(--s1)}
.mapbg{width:100%;height:100%;background:var(--g1);position:relative}
.mgrid{position:absolute;inset:0;background-image:repeating-linear-gradient(var(--g2) 0 1px,transparent 1px 40px),repeating-linear-gradient(90deg,var(--g2) 0 1px,transparent 1px 50px)}
.mrhh{position:absolute;background:#fff;border:1px solid var(--g2)}.mrvv{position:absolute;background:#fff;border:1px solid var(--g2)}
.mblk{position:absolute;border-radius:6px;background:var(--g2)}
.mpin{position:absolute;cursor:pointer;transform:translate(-50%,-100%)}
.pbbl{background:#fff;border:1.5px solid var(--g3);border-radius:10px;padding:5px 10px;font-size:12px;font-weight:700;color:var(--g8);white-space:nowrap;box-shadow:0 3px 12px rgba(0,0,0,.12);position:relative}
.pbbl::after{content:'';position:absolute;bottom:-7px;left:50%;transform:translateX(-50%);border:5px solid transparent;border-top-color:var(--g3)}
.pbbl.ok{border-color:var(--green);color:var(--gd);background:#F0FDF4}.pbbl.ok::after{border-top-color:var(--green)}
.pbbl.warn{border-color:var(--amber);color:var(--amd);background:#FFFBEB}.pbbl.warn::after{border-top-color:var(--amber)}
.myloc{position:absolute;width:16px;height:16px;border-radius:50%;background:var(--blue);border:3px solid #fff;box-shadow:0 0 0 6px rgba(26,86,219,.15)}
/* DETAIL */
.gall{height:220px;background:var(--blue-lt);display:flex;align-items:center;justify-content:center;font-size:64px;position:relative;overflow:hidden;flex-shrink:0}
.gov{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 50%,rgba(15,23,42,.5) 100%)}
.gcnt{position:absolute;bottom:12px;right:12px;background:rgba(0,0,0,.55);color:#fff;border-radius:8px;padding:4px 10px;font-size:12px;font-weight:600}
.gdots{position:absolute;bottom:12px;left:50%;transform:translateX(-50%);display:flex;gap:5px}
.gd{width:6px;height:6px;border-radius:50%;background:rgba(255,255,255,.4)}.gd.on{background:#fff;width:16px;border-radius:3px}
.dbody{padding:16px 20px}.dname{font-size:20px;font-weight:800;color:var(--g9);margin-bottom:4px;line-height:1.25}
.daddr{font-size:13px;color:var(--g5);margin-bottom:12px}.dpills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:16px}
.amen-row{display:flex;gap:10px;overflow-x:auto;margin:0 -20px;padding:0 20px 4px}.amen-row::-webkit-scrollbar{display:none}
.amen{display:flex;flex-direction:column;align-items:center;gap:6px;background:#fff;border:1.5px solid var(--g2);border-radius:var(--r2);padding:12px 14px;min-width:68px;flex-shrink:0;box-shadow:var(--s1)}
.ai{font-size:20px}.al{font-size:11px;font-weight:600;color:var(--g5);text-align:center;line-height:1.3}
.zi{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.zb{font-size:11px;font-weight:700;padding:4px 10px;border-radius:100px}
.zb.res{background:var(--blue-lt);color:var(--blue2)}.zb.opn{background:var(--g1);color:var(--g6)}
.sleg{display:flex;gap:12px;margin-bottom:12px}.le{display:flex;align-items:center;gap:5px;font-size:11px;font-weight:600;color:var(--g5)}
.ld{width:10px;height:10px;border-radius:3px}
.sfll{font-size:11px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--g4);margin-bottom:8px}
.sgrid{display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-bottom:16px}
.slot{height:36px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;cursor:pointer;border:1.5px solid transparent}
.slot.free{background:var(--gl);color:var(--gd);border-color:#A7F3D0}.slot.free:active{background:#BBF7D0}
.slot.taken{background:var(--g1);color:var(--g3);cursor:not-allowed}
.slot.sel{background:var(--blue);color:#fff;border-color:var(--blue2);box-shadow:0 2px 8px rgba(26,86,219,.3)}
.slot.opz{background:var(--aml);color:var(--amd);cursor:not-allowed;border-color:#FDE68A}
.ravg{display:flex;align-items:center;gap:16px;background:var(--g0);border-radius:var(--r3);padding:16px;margin-bottom:14px;border:1px solid var(--g2)}
.rbig{font-size:40px;font-weight:800;color:var(--g9);line-height:1}.rss{font-size:16px;color:var(--amber)}.rct{font-size:12px;color:var(--g4);margin-top:4px}
.rbars{flex:1}.rrow{display:flex;align-items:center;gap:7px;margin-bottom:4px}
.rs{font-size:11px;color:var(--g5);min-width:8px}.rbg{flex:1;height:5px;background:var(--g2);border-radius:3px;overflow:hidden}
.rf{height:100%;border-radius:3px;background:var(--amber)}.rp{font-size:10px;color:var(--g4);min-width:28px;text-align:right}
.rcard{background:#fff;border:1.5px solid var(--g2);border-radius:var(--r3);padding:14px;margin-bottom:10px;box-shadow:var(--s1)}
.rhead{display:flex;align-items:center;gap:10px;margin-bottom:8px}
.rav{width:36px;height:36px;border-radius:50%;background:var(--blue-ln);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:var(--blue2);flex-shrink:0}
.rnm{font-size:14px;font-weight:700;color:var(--g9)}.rdt{font-size:11px;color:var(--g4)}.rst{color:var(--amber);font-size:12px;margin-left:auto}
.rtxt{font-size:13px;color:var(--g6);line-height:1.6}
/* BOOKING */
.bsum{margin:16px 20px;background:#fff;border:1.5px solid var(--g2);border-radius:var(--r3);padding:14px;display:flex;gap:12px;align-items:center;box-shadow:var(--s1)}
