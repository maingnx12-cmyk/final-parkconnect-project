function PKT(t){document.getElementById('ptM').classList.toggle('on',t==='month');document.getElementById('ptQ').classList.toggle('on',t==='quarter');if(t==='quarter'){document.getElementById('pp-price').innerHTML='811.000₫ <span>/ tháng</span>';document.getElementById('pp-saving').textContent='Thanh toán 2.433.000₫/quý · Tiết kiệm 8%';document.getElementById('pu-price').innerHTML='2.565.000₫ <span>/ quý</span>';document.getElementById('pu-saving').textContent='= 855.000₫/tháng · Giảm 5% mỗi lượt đỗ';}else{document.getElementById('pp-price').innerHTML='882.000₫ <span>/ tháng</span>';document.getElementById('pp-saving').textContent='≈ 29.400₫/ngày · Hoàn vốn từ ~100 lượt/tháng';document.getElementById('pu-price').innerHTML='2.565.000₫ <span>/ quý</span>';document.getElementById('pu-saving').textContent='= 855.000₫/tháng · Tiết kiệm hơn Premium';}}
