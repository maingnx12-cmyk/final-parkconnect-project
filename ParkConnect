  addSec('3','PHÂN TÍCH HOẠT ĐỘNG DỰ ÁN',['3.1 – Xây dựng cơ cấu tổ chức','3.2 – Dự toán Chi phí và Doanh thu','3.3 – Xác định điểm hòa vốn']);
  addC('3.1.1','Mô hình tổ chức và lý luận lựa chọn',['Mô hình chức năng (Functional Organizational Structure) – Mintzberg (1979)','Phù hợp startup quy mô nhỏ giai đoạn tăng trưởng sớm','Tối đa hóa hiệu quả qua chuyên môn hóa sâu | Mỗi NV chỉ có 1 cấp trên trực tiếp','Nguyên tắc Lean Startup: chỉ tuyển khi thực sự cần thiết','Tổng nhân sự: 14 người (1 CEO + 13 nhân viên)']);
  addC('3.1.2','Sơ đồ tổ chức',['##CEO (1 người) – Trung tâm điều phối','Phòng Kinh doanh: 1 Trưởng phòng + 2 Nhân viên','Phòng Nhân sự – Hành chính: 1 người','Phòng Công nghệ Thông tin: Tech Lead + 2 Backend/App Dev + 1 UI/UX','Phòng Tài chính – Kế toán: Kế toán trưởng + 1 Kế toán viên','Phòng Marketing: 1 Chiến lược + 1 Design + 1 Ads & Seeding']);
  addC('3.1.3','Mô tả chi tiết từng vị trí – CEO & Phòng Kinh doanh',['CEO (1): chiến lược, gọi vốn, đại diện thương hiệu, kiêm thủ quỹ – 30 triệu/tháng','Trưởng phòng KD (1): xây quy trình, quản lý đội, ký kết bãi xe cấp cao – 15 triệu','NV KD (2): tiếp cận thực địa theo khu vực địa lý phân công – 7–9 triệu + KPI','##KPI chính:','Số bãi ký kết/tháng, tỷ lệ bãi gia hạn ≥80% sau tháng 6','Mục tiêu Giai đoạn 1: ký 20–30 bãi xe tại Q1 và Q3']);
  addC('3.1.3','Mô tả chi tiết từng vị trí – CNTT & Marketing & Tài chính',['Tech Lead (1): kiến trúc microservices, quản lý tiến độ – 18–25 triệu','Backend Dev (2): API, real-time, tích hợp thanh toán/Maps – 10–13 triệu/người','UI/UX (1): giao diện iOS & Android, luồng ≤3 bước – 8–12 triệu','Marketing (3): chiến lược + design + ads & seeding – 7–10 triệu','Kế toán trưởng (1): báo cáo tài chính, thuế, dòng tiền – 12–15 triệu','Kế toán viên (1) + Nhân sự–Hành chính (1): 8–10 triệu']);
  addC('3.2.1','Dự toán chi phí đầu tư ban đầu',['##Mục A – Thành lập doanh nghiệp: ~6,55 triệu','Đăng ký, khắc dấu, tư vấn pháp lý (hợp đồng mẫu, TOS, Privacy Policy)','##Mục B – Văn phòng & cơ sở vật chất ban đầu: 21 triệu','Đặt cọc 1 tháng hot desk tại cirCO Điện Biên Phủ','##Mục C – Phát triển ứng dụng: ~47 triệu','App Store 2,6M + Play Console 700K + Cloud 5–10M + Pentest bảo mật 20–30M','##TỔNG ĐẦU TƯ BAN ĐẦU: ~74,55 triệu VNĐ | Vốn tự thân: 1 tỷ VNĐ']);
  addC('3.2.2a','Chi phí vận hành hàng tháng – Chi phí cố định (Fixed Costs)',['Lương nhân sự 13 người (bao gồm BHXH/BHYT/BHTN 21,5%): 160 triệu/tháng','Văn phòng cirCO Điện Biên Phủ (điện, nước, internet, lễ tân): 21 triệu/tháng','Cloud infrastructure AWS/GCP production: 8 triệu/tháng','Phần mềm công cụ (Slack, Notion, Figma, Jira): 3 triệu/tháng','Bảo hiểm & chi phí pháp lý định kỳ (kiểm toán, tư vấn): 2 triệu/tháng','##TỔNG CHI PHÍ CỐ ĐỊNH: 194 triệu/tháng']);
  addC('3.2.2b','Chi phí vận hành hàng tháng – Chi phí biến đổi (Variable Costs)',['Marketing & Quảng cáo (Facebook/Google Ads): 20 triệu/tháng','Chi phí SMS/OTP xác thực (~500đ/SMS × số giao dịch): 3 triệu/tháng','Phí API bên thứ ba (Maps, Payment gateway): 5 triệu/tháng','Hoa hồng nhân viên (1–1,5%/giao dịch): 20 triệu/tháng','Chi phí di chuyển nhân viên kinh doanh/đối tác: 3,5 triệu/tháng','Khác (in ấn, quà tặng đối tác, chi phí phát sinh): 4 triệu/tháng','##TỔNG CHI PHÍ BIẾN ĐỔI: 53,5 triệu/tháng']);
  addC('3.2.3a','Dự toán doanh thu – Cơ cấu giá bán và nguồn thu',['##Giai đoạn 1: Hoa hồng giao dịch 21–23% / lượt đỗ thành công','##Giai đoạn 2: + Phí sàn Basic 850.000 VNĐ/bãi/tháng + Gói Premium 882K + Ultra 2,565M/quý','##Giai đoạn 3: + Phí sàn VIP 4.500.000 VNĐ/bãi/tháng + Quảng cáo CPC/CPM','##Giai đoạn 4: Tất cả nguồn thu vận hành đồng thời – hệ sinh thái hoàn chỉnh','Chiến lược: cuốn chiếu theo quy mô – không thu phí cố định khi chưa đủ network']);
  addC('3.2.3b','Dự toán doanh thu – Lộ trình triển khai các nguồn thu',['GĐ1 (Ra mắt): chỉ hoa hồng giao dịch → giảm tối đa rào cản gia nhập cho chủ bãi','GĐ2 (Tăng tốc): + Phí sàn Basic + Gói Premium/Ultra → đa dạng hóa dòng tiền','GĐ3 (Mở rộng): + Phí sàn VIP + Quảng cáo → khai thác lượng người dùng lớn','GĐ4 (Ổn định): tất cả nguồn thu vận hành đồng thời → hệ sinh thái hoàn chỉnh','Chiến lược tương tự Grab, Airbnb: tập trung user trước, monetize sau']);
  addC('3.2.3c','Dự toán doanh thu – Giai đoạn 1 (Tháng 1–3)',['Giả định: 2.500 users | 15 bãi xe | 15 lượt/ngày/bãi | 90% thành công = 203 lượt/ngày','Giá TB: 30.000 VNĐ | Hoa hồng 23%','Doanh thu: 203 × 6.900 × 30 = 42.021.000 VNĐ/tháng','Tổng chi phí: 247,5 triệu/tháng (cố định 194M + biến đổi 53,5M)','##KẾT QUẢ: Lỗ 205.479.000 VNĐ/tháng','WACMR: -27,31% → Điểm hòa vốn KHÔNG TỒN TẠI – giai đoạn đốt tiền mua network']);
