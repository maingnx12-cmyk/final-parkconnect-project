<!DOCTYPE html>
<html><head><meta charset="UTF-8">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI',sans-serif;background:linear-gradient(135deg,#0F3490,#1A56DB);min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px}
.card{background:#fff;border-radius:24px;padding:40px 36px;max-width:480px;width:100%;text-align:center;box-shadow:0 30px 80px rgba(0,0,0,.3)}
.logo{font-size:64px;margin-bottom:12px}
.badge{display:inline-block;background:#EEF4FF;color:#1A56DB;border-radius:100px;padding:5px 16px;font-size:12px;font-weight:700;margin-bottom:14px;letter-spacing:.04em}
h1{font-size:30px;font-weight:800;color:#0F172A;margin-bottom:6px}
.sub{color:#64748B;font-size:14px;line-height:1.7;margin-bottom:28px}
.features{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:28px;text-align:left}
.feat{background:#F8FAFC;border-radius:10px;padding:10px 12px;font-size:12px;color:#475569;display:flex;align-items:center;gap:8px}
.feat span{font-size:18px}
.btn{background:linear-gradient(135deg,#1A56DB,#0F3490);color:#fff;border:none;padding:16px 32px;border-radius:14px;font-size:16px;font-weight:700;cursor:pointer;width:100%;transition:all .2s;letter-spacing:.02em}
.btn:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(26,86,219,.4)}
.btn:disabled{background:#94A3B8;cursor:not-allowed;transform:none;box-shadow:none}
.prog{margin-top:18px;font-size:13px;color:#64748B;min-height:22px}
.bar-wrap{background:#E2E8F0;border-radius:100px;height:6px;margin-top:10px;overflow:hidden;display:none}
.bar{height:100%;background:linear-gradient(90deg,#1A56DB,#4D82FF);border-radius:100px;width:0%;transition:width .3s}
</style>
</head>
<body>
<div class="card">
  <div class="logo">🅿</div>
  <div class="badge">62 SLIDES • ĐẦY ĐỦ NỘI DUNG BÁO CÁO</div>
  <h1>ParkConnect</h1>
  <p class="sub">Tạo file PowerPoint (.pptx) với đầy đủ 62 slide, giữ nguyên tiêu đề theo cấu trúc báo cáo (1.1.1, 1.1.2a, 2.1.1...), phong cách hiện đại công nghệ.</p>
  <div class="features">
    <div class="feat"><span>📋</span>62 slides chi tiết</div>
    <div class="feat"><span>🎨</span>Style tech hiện đại</div>
    <div class="feat"><span>🔢</span>Tiêu đề theo báo cáo</div>
    <div class="feat"><span>👥</span>MSSV từng thành viên</div>
    <div class="feat"><span>📊</span>Số liệu tài chính đầy đủ</div>
    <div class="feat"><span>⬇</span>Tải về máy ngay</div>
  </div>
  <button class="btn" id="btn" onclick="gen()">⬇ Tạo & Tải PowerPoint</button>
  <div class="prog" id="prog"></div>
  <div class="bar-wrap" id="bw"><div class="bar" id="bar"></div></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pptxgenjs/3.12.0/pptxgen.bundle.js"></script>
<script>
async function gen(){
  const btn=document.getElementById('btn'),prog=document.getElementById('prog'),bw=document.getElementById('bw'),bar=document.getElementById('bar');
  btn.disabled=true;btn.textContent='⏳ Đang tạo...';bw.style.display='block';
  const steps=['Khởi tạo...','Slide bìa & thành viên...','Phần 1 – Tổng quan...','Phần 2 – PESTEL & Vi mô...','Phần 3 – Tổ chức & Tài chính...','Phần 4,5,6 – Rủi ro & Lộ trình...','Xuất file PowerPoint...'];
  let si=0;
  function setP(t,p){prog.textContent=steps[si++]||t;bar.style.width=p+'%';}

  const pptx=new PptxGenJS();
  pptx.layout='LAYOUT_WIDE';
  pptx.title='ParkConnect – Dự án Kinh doanh Quốc tế';
  pptx.author='Nhóm 2 IB0003 UEH';
  const W=13.33,H=7.5;
  const C={bd:'0F3490',bm:'1A56DB',bl:'4D82FF',blt:'EEF4FF',
            w:'FFFFFF',g0:'F8FAFC',g2:'E2E8F0',g5:'64748B',g7:'334155',g9:'0F172A',
            gr:'10B981',am:'F59E0B',rd:'EF4444',navy:'1E3A8A'};

  setP('',5);await p(20);

  // ── COVER ──────────────────────────────────────────
  {let s=pptx.addSlide();
  s.addShape(pptx.ShapeType.rect,{x:0,y:0,w:W,h:H,fill:{color:C.bd}});
  s.addShape(pptx.ShapeType.rect,{x:0,y:0,w:4.5,h:H,fill:{color:'1445B8'},transparency:55});
  s.addShape(pptx.ShapeType.rect,{x:0,y:H-0.12,w:W,h:0.12,fill:{color:C.bl}});
  s.addText('🅿',{x:0.7,y:0.7,w:2,h:2,fontSize:80,align:'center',color:C.w});
  s.addText('PARKCONNECT',{x:0.5,y:2.7,w:12.5,h:1.3,fontSize:50,bold:true,color:C.w,fontFace:'Arial',charSpacing:4,wrap:true});
  s.addText('Ứng dụng kết nối chủ bãi đỗ xe với người lái xe',{x:0.5,y:3.9,w:12.5,h:0.7,fontSize:19,color:'B3CCFF',fontFace:'Arial'});
  s.addShape(pptx.ShapeType.rect,{x:0.5,y:4.8,w:12,h:0.04,fill:{color:'1E3A8A'}});
  s.addText('Bộ GD&ĐT  •  Đại học Kinh tế TP. Hồ Chí Minh  •  Trường Kinh doanh  •  Khoa KDQT - Marketing',{x:0.5,y:5.0,w:12.5,h:0.4,fontSize:12,color:'94A3B8',fontFace:'Arial'});
  s.addText('Học phần: Dự án Kinh doanh Quốc tế  •  Mã lớp: 26D1BUS50301303  •  GVHD: Ts. Đinh Thị Thu Oanh',{x:0.5,y:5.4,w:12.5,h:0.4,fontSize:12,color:'94A3B8',fontFace:'Arial'});
  s.addText('Nhóm 2  •  Lớp IB0003  •  Khóa 49  •  TP. Hồ Chí Minh, ngày 06/06/2026',{x:0.5,y:5.85,w:12.5,h:0.4,fontSize:12,color:'64748B',fontFace:'Arial'});}

  // ── MEMBERS ─────────────────────────────────────────
  {let s=pptx.addSlide();
  s.background={color:C.g0};
  s.addShape(pptx.ShapeType.rect,{x:0,y:0,w:W,h:1.4,fill:{color:C.bd}});
  s.addShape(pptx.ShapeType.rect,{x:0,y:1.4,w:W,h:0.07,fill:{color:C.bl}});
  s.addText('THÀNH VIÊN NHÓM 2',{x:0.5,y:0.15,w:12,h:0.65,fontSize:28,bold:true,color:C.w,fontFace:'Arial'});
  s.addText('Lớp IB0003  •  Khóa 49  •  Đại học Kinh tế TP. Hồ Chí Minh',{x:0.5,y:0.82,w:12,h:0.45,fontSize:14,color:'B3CCFF',fontFace:'Arial'});
  const mems=[{n:'01',nm:'Nguyễn Xuân Mai',id:'31231022594'},{n:'02',nm:'Hoàng Thị Thùy Dương',id:'31231021003'},{n:'03',nm:'Văn Mỹ Xuân',id:'31231024827'},{n:'04',nm:'Võ Nguyên Thắng',id:'31231026274'},{n:'05',nm:'Lê Anh Tài',id:'31231026359'}];
  const pos=[{x:0.3,y:1.65},{x:4.1,y:1.65},{x:7.9,y:1.65},{x:2.2,y:4.2},{x:6.0,y:4.2}];
  mems.forEach(({n,nm,id},i)=>{
    const{x,y}=pos[i],w=3.7,h=2.2;
    s.addShape(pptx.ShapeType.rect,{x,y,w,h,fill:{color:C.w},line:{color:C.g2,width:1},shadow:{type:'outer',blur:6,offset:2,angle:45,color:'000000',opacity:.08}});
    s.addShape(pptx.ShapeType.rect,{x,y,w,h:0.52,fill:{color:C.bm}});
    s.addText(n,{x,y:y+0.06,w,h:0.42,fontSize:18,bold:true,color:C.w,align:'center',fontFace:'Arial'});
    s.addText(nm,{x:x+0.1,y:y+0.62,w:w-0.2,h:0.85,fontSize:14,bold:true,color:C.g9,align:'center',wrap:true,fontFace:'Arial',valign:'middle'});
    s.addShape(pptx.ShapeType.rect,{x:x+0.35,y:y+1.55,w:w-0.7,h:0.03,fill:{color:C.g2}});
    s.addText('MSSV: '+id,{x,y:y+1.65,w,h:0.4,fontSize:13,color:C.bm,align:'center',bold:true,fontFace:'Arial'});
  });}

  setP('',12);await p(20);

  // ── HELPERS ─────────────────────────────────────────
  function hdr(s,sec,title){
    s.addShape(pptx.ShapeType.rect,{x:0,y:0,w:W,h:1.38,fill:{color:C.bm}});
    s.addShape(pptx.ShapeType.rect,{x:0,y:1.38,w:W,h:0.07,fill:{color:C.bl}});
    s.addShape(pptx.ShapeType.rect,{x:0,y:0,w:0.14,h:1.38,fill:{color:C.bd}});
    s.addText(sec,{x:0.3,y:0.08,w:12.8,h:0.4,fontSize:11,bold:true,color:'B3CCFF',fontFace:'Arial',charSpacing:2});
    s.addText(title,{x:0.3,y:0.46,w:12.8,h:0.86,fontSize:20,bold:true,color:C.w,fontFace:'Arial',wrap:true,valign:'middle'});
  }

  function addC(sec,title,items){
    let s=pptx.addSlide();
    s.background={color:C.g0};
    hdr(s,sec,title);
    let y=1.62;
    items.forEach(item=>{
      if(item.startsWith('##')){
        let t=item.slice(2).trim();
        s.addShape(pptx.ShapeType.rect,{x:0.38,y,w:12.6,h:0.5,fill:{color:C.blt},line:{color:'D9E5FF',width:0.5}});
        s.addText(t,{x:0.56,y:y+0.08,w:12.2,h:0.36,fontSize:12.5,bold:true,color:C.bm,fontFace:'Arial',wrap:true});
        y+=0.56;
      } else {
        s.addShape(pptx.ShapeType.rect,{x:0.38,y:y+0.19,w:0.1,h:0.1,fill:{color:C.bm}});
        s.addText(item,{x:0.62,y,w:12.2,h:0.48,fontSize:13.5,color:C.g7,fontFace:'Arial',wrap:true});
        y+=0.5;
      }
    });
  }

  function addSec(num,title,subs){
    let s=pptx.addSlide();
    s.addShape(pptx.ShapeType.rect,{x:0,y:0,w:W,h:H,fill:{color:C.bd}});
    s.addShape(pptx.ShapeType.rect,{x:0,y:0,w:0.55,h:H,fill:{color:C.bl}});
    s.addShape(pptx.ShapeType.rect,{x:0,y:H-1.4,w:W,h:1.4,fill:{color:C.navy}});
    s.addText('PHẦN',{x:1,y:0.75,w:5,h:0.6,fontSize:13,bold:true,color:'4D82FF',fontFace:'Arial',charSpacing:12});
    s.addText(num,{x:0.7,y:1.1,w:3.5,h:2.8,fontSize:130,bold:true,color:'1445B8',fontFace:'Arial'});
    s.addText(title,{x:1,y:2.9,w:11.8,h:1.5,fontSize:34,bold:true,color:C.w,fontFace:'Arial',wrap:true});
    subs.forEach((sub,i)=>s.addText('→  '+sub,{x:1,y:4.55+i*0.42,w:11.8,h:0.4,fontSize:13,color:'94A3B8',fontFace:'Arial'}));
  }

  function p(ms){return new Promise(r=>setTimeout(r,ms));}

  // ── TOC ─────────────────────────────────────────────
  addC('MỤC LỤC','Nội dung trình bày',['##Phần 1 – Tổng quan dự án','##Phần 2 – Phân tích môi trường kinh doanh (PESTEL + Porter\'s Five Forces)','##Phần 3 – Phân tích hoạt động dự án (Tổ chức – Chi phí – Doanh thu – Hòa vốn)','##Phần 4 – Quản trị rủi ro dự án','##Phần 5 – Đánh giá hiệu quả dự án (Balanced Scorecard)','##Phần 6 – Dự án trong giai đoạn kế tiếp & Tầm nhìn dài hạn']);

  setP('',20);await p(20);

  // ══ PHẦN 1 ══════════════════════════════════════════
  addSec('1','TỔNG QUAN DỰ ÁN',['1.1 – Xác định sản phẩm kinh doanh','1.2 – Xác định địa điểm kinh doanh','1.3 – Xác định thị trường và khách hàng mục tiêu']);
  addC('1.1','Xác định sản phẩm kinh doanh',['ParkConnect: nền tảng kỹ thuật số hai chiều chuyên về quản lý và đặt chỗ đỗ xe thông minh','Vận hành trên môi trường ứng dụng di động (iOS & Android)','Bao gồm: giao diện người dùng + giao diện quản trị chủ bãi + hạ tầng công nghệ','Không xây thêm bãi xe – làm bãi hiện có hoạt động thông minh hơn','Giải quyết đồng thời vấn đề từ phía người dùng và chủ bãi xe']);
  addC('1.1.1','Tên, nhận diện và phạm vi sản phẩm',['Tên: PARKCONNECT – "Park" (đỗ xe) + "Connect" (kết nối)','Triết lý: kết nối bãi đỗ xe và người lái xe trong một hệ sinh thái khép kín','Phạm vi ban đầu: TP.HCM và Hà Nội – áp lực đỗ xe cao nhất, thanh toán điện tử phổ biến','Lộ trình mở rộng: 15 thành phố lớn trong vòng 3 năm đầu vận hành','Sản phẩm không chỉ là app tra cứu – là hệ sinh thái vận hành khép kín']);
  addC('1.1.2a','Vấn đề thực tế – Góc nhìn từ phía người dùng',['Nỗi đau 1 – Không chắc chắn: không biết bãi còn chỗ cho đến khi đến nơi','Nỗi đau 2 – Lãng phí thời gian: trung bình 15–25 phút/ngày tìm chỗ đỗ (~150 giờ/năm)','Nỗi đau 3 – Rủi ro tài sản: bãi thủ công, không camera, không bảo hiểm, không xác thực','Không có công cụ đặt hộ cho người thân hoặc đồng nghiệp','71% người dùng đang "chạy vòng quanh cho đến khi thấy bãi" – rất thiếu hiệu quả']);
  addC('1.1.2b','Vấn đề thực tế – Góc nhìn từ phía chủ bãi xe',['Không có dữ liệu lượng xe vào ra theo giờ','Không biết chỗ nào trống, chỗ nào có xe theo thời gian thực','Không phân bổ được giữa khách đặt trước và khách vãng lai','Tỷ lệ lấp đầy trung bình chỉ 55–65% – bỏ phí doanh thu đáng kể','Vận hành hoàn toàn thủ công: ghi vé giấy, thu tiền mặt']);
  addC('1.1.2c','Giải pháp tổng thể của ParkConnect',['Kết nối nền tảng duy nhất – giải quyết đồng thời cả hai phía cung và cầu','Hiển thị chỗ trống real-time, cho phép đặt và thanh toán trước','Trang bị dashboard vận hành và phân tích dữ liệu cho chủ bãi','Không xây thêm bãi – tối ưu hóa bãi hiện có','Tương tự mô hình Grab (gọi xe) và Airbnb (lưu trú) – network effect hai chiều']);
  addC('1.1.3a','Đối tượng phục vụ – Người dùng (Nhóm khách hàng cá nhân)',['Người điều khiển phương tiện cá nhân tại đô thị: xe máy, ô tô, SUV','Độ tuổi 22–45, nhân viên văn phòng, chuyên gia, doanh nhân, thu nhập trung bình trở lên','Đến khu trung tâm ≥3 lần/tuần, quen dùng smartphone & thanh toán điện tử','Sẵn sàng chi thêm 10.000–15.000 VNĐ/lượt để đỗ xe tiện lợi, chắc chắn','56,8% sẵn sàng chuyển sang ParkConnect nếu giải quyết được khó khăn hiện tại']);
  addC('1.1.3b','Đối tượng phục vụ – Chủ bãi xe (Nhóm đối tác vận hành)',['Chủ sở hữu/quản lý bãi xe tư nhân quy mô 10–200 chỗ','Bãi ngầm TTTM, bãi độc lập, tòa nhà văn phòng, khu đô thị','Vận hành truyền thống: thu tiền mặt, không hệ thống quản lý số','Nhu cầu số hóa cao nhưng không có nguồn lực tự phát triển','Rào cản gia nhập cực thấp: chỉ cần điện thoại cài app quản lý là vận hành được']);
  addC('1.1.4','Tính năng cốt lõi của ứng dụng – Tổng quan',['##a) Tìm kiếm và xem thông tin thời gian thực','##b) Sơ đồ chỗ đỗ và phân tách khu vực','##c) Đặt chỗ, khai báo biển số và tính năng đặt hộ','##d) Xác thực QR và vận hành cổng bãi xe','##e) Gia hạn giờ đỗ ngay trên ứng dụng','##f) Thanh toán đa kênh, không tiền mặt']);
  addC('1.1.4a','Tính năng – Tìm kiếm và xem thông tin thời gian thực',['Tìm theo tên địa điểm, khu vực, địa chỉ hoặc GPS vị trí hiện tại','Hiển thị: số chỗ trống, giá/giờ, khoảng cách, điểm đánh giá, tiện ích','Chuyển đổi linh hoạt: chế độ danh sách ↔ chế độ bản đồ','Lọc theo: loại xe (xe máy, ô tô, SUV, xe điện), khu vực, tiện ích (mái che, camera, EV)','Dữ liệu cập nhật liên tục – live từ bãi xe đối tác']);
  addC('1.1.4b','Tính năng – Sơ đồ chỗ đỗ và phân tách khu vực',['Hiển thị sơ đồ bãi xe trực quan theo từng tầng và hàng','Màu sắc trạng thái: xanh lá (trống), xám (có xe), xanh dương (đã chọn), cam vàng (vãng lai)','Phân tách vật lý Khu đặt trước vs Khu vãng lai ngay trên sơ đồ','Khu đặt trước: biển hiệu màu xanh, sơn kẻ nền, trụ chắn từng ô','Tỷ lệ phân chia do chủ bãi tự quyết định và điều chỉnh linh hoạt theo khung giờ']);
  addC('1.1.4c','Tính năng – Đặt chỗ, khai báo biển số và tính năng đặt hộ',['Luồng tối giản: chọn ô → nhập biển số → chọn giờ → thanh toán (≤6 thao tác)','Biển số bắt buộc – liên kết trực tiếp với mã QR xác thực tại cổng','Chỗ giữ tối đa 30 phút – quá giờ tự động hủy, không hoàn tiền','Đặt hộ: khai báo biển số xe người thân/đồng nghiệp thay cho xe của mình','Camera LPR tự động nhận diện biển số – người được đặt hộ vào bãi không cần thao tác gì']);
  addC('1.1.4d','Tính năng – Xác thực QR và vận hành cổng bãi xe',['Sau thanh toán: hệ thống sinh QR động chứa chữ ký số','QR gắn kết: mã đặt chỗ + biển số + ô đỗ cụ thể + khung giờ hợp lệ','Offline-capable: xác thực ngay cả khi mất mạng di động','Kết hợp camera LPR xác thực hai lớp (QR + biển số)','Xử lý ngoại lệ: đến muộn, lỗi QR, mất kết nối, biển số không khớp']);
  addC('1.1.4e','Tính năng – Gia hạn giờ đỗ ngay trên ứng dụng',['Thông báo khi còn 15 phút trước giờ hết hạn','Gia hạn ngay trên điện thoại: +30 phút / +1 giờ / +2 giờ / +3 giờ','Không cần ra khỏi xe hay tìm nhân viên','Hệ thống kiểm tra tự động xem chỗ đó đã được đặt tiếp chưa','Phí gia hạn trừ tự động từ ví điện tử đã liên kết']);
  addC('1.1.4f','Tính năng – Thanh toán đa kênh, không tiền mặt',['Hỗ trợ: MoMo, ZaloPay, VNPay, thẻ ngân hàng nội địa/quốc tế (Visa/Mastercard)','Tùy chọn tiền mặt tại quầy cho khách chưa có tài khoản số','Mã hóa SSL 256-bit – thông tin thẻ không lưu trên server ParkConnect','Xử lý qua cổng thanh toán được cấp phép bởi NHNN Việt Nam','Sau thanh toán: sinh QR duy nhất, offline-capable ngay lập tức']);
  addC('1.1.5','Quản lý lưu thông xe vào/ra và xử lý ùn tắc',['Quét QR + camera LPR: hai lớp xác thực, giảm ùn tắc cổng giờ cao điểm','Đến muộn >30 phút: ô đỗ cho khách vãng lai tạm thời, người đặt không hoàn tiền','Lỗi mã QR (hết pin, app lỗi): nhân viên tra thủ công qua biển số hoặc họ tên','Hệ thống mất kết nối: QR offline-capable xác thực cục bộ, đồng bộ khi phục hồi','Bãi đầy hoàn toàn: tự động dừng nhận đặt mới, gợi ý bãi thay thế trong 500m']);
  addC('1.2.1','Thị trường mục tiêu – Khu vực triển khai',['Giai đoạn 1: Quận 1, Quận 3, Quận 5, Quận 10 – tổng 16,73 km²','Tập trung tòa nhà văn phòng hạng A, TTTM, bệnh viện, cơ quan hành chính','Nhu cầu đỗ xe thường xuyên và ổn định – lý tưởng kiểm chứng sản phẩm','102.400 ô tô đăng ký mới tại TP.HCM năm 2025 – cao nhất cả nước','Khoảng trống thị trường: cần 550 ha bãi đỗ, chỉ có 2,69 ha (<0,5%)']);
  addC('1.2.2','Lựa chọn và phân tích địa chỉ văn phòng',['Mô hình làm việc hybrid – tối ưu chi phí, phù hợp startup giai đoạn đầu','Giải pháp: Coworking space tại cirCO Điện Biên Phủ (Quận 3)','Gói văn phòng ảo: 400.000 VNĐ/tháng – địa chỉ kinh doanh + lễ tân + bảng tên','7 vị trí hot desk: 3.000.000 VNĐ/người/tháng × 7 = 21.000.000 VNĐ/tháng','Tổng chi phí văn phòng: ~21 triệu VNĐ/tháng']);
  addC('1.3','Xác định thị trường và khách hàng mục tiêu',['B2C (End Users): lái xe ô tô 22–45 tuổi tại TP.HCM, đến trung tâm ≥3 lần/tuần','B2B (Parking Operators): chủ bãi tư nhân SME 10–200 chỗ, vận hành truyền thống','50,3% người được hỏi lái xe ít nhất 3 lần/tuần','56,8% sẵn sàng chuyển sang ParkConnect nếu giải quyết được khó khăn hiện tại','ParkConnect cung cấp giải pháp trọn gói chi phí thấp hơn tự đầu tư công nghệ']);

