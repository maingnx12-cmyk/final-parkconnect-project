  addSec('2','PHÂN TÍCH MÔI TRƯỜNG KINH DOANH',['2.1 – Môi trường vĩ mô (PESTEL)','2.2 – Môi trường vi mô']);
  addC('2.1.1','Yếu tố Chính trị (Political)',['Việt Nam top 41/163 quốc gia hòa bình & ổn định (GPI 2024)','Chương trình Chuyển đổi số quốc gia 2021–2025 (QĐ 942/QĐ-TTg)','TP.HCM: định hướng đô thị thông minh 2022–2025, tầm nhìn đến 2030','Ứng dụng IoT, AI, Big Data vào quản lý hạ tầng đô thị – cơ hội hợp tác công tư']);
  addC('2.1.2','Yếu tố Kinh tế (Economic)',['GDP Việt Nam 2024: tăng 7,09% – cao nhất Đông Nam Á (IMF, 2025)','GDP bình quân TP.HCM: ~7.000 USD/người | 102.400 ô tô mới đăng ký 2025','Ùn tắc gây thiệt hại 138.000 tỷ đồng/năm (Sở GTVT TP.HCM, 2022)','Khoảng trống thị trường: cần 550 ha bãi đỗ, chỉ có 2,69 ha (<0,5% nhu cầu)']);
  addC('2.1.3','Yếu tố Xã hội (Social)',['Dân số 2026: 102,6 triệu, 50% dưới 35 tuổi – Millennials & Gen Z chủ đạo','78 triệu người dùng internet di động, 90% qua smartphone (Google/Temasek, 2024)','Thanh toán không tiền mặt tăng từ 4,9% (2019) lên 19,9% (2023)','70% người khảo sát đánh giá tính năng cashless là hấp dẫn']);
  addC('2.1.4','Yếu tố Công nghệ (Technological)',['4G phủ sóng 99% dân số, 5G triển khai thương mại tại TP.HCM & Hà Nội','Cloud computing (AWS/GCP): startup package ~3–7 triệu/tháng','Chi phí cảm biến IoT giảm 60–70% trong 5 năm: 300.000–800.000 VNĐ/cảm biến','Kiến trúc microservices trên cloud: mở rộng linh hoạt theo user thực tế']);
  addC('2.1.5','Yếu tố Môi trường (Environmental)',['Giao thông chiếm 30–40% CO₂ tại TP.HCM, ~13 triệu tấn/năm (CESTI, 2025)','PM2.5 trung bình TP.HCM: 28,6 µg/m³ – cao hơn 3–5 lần khuyến nghị WHO','Cruising (tìm chỗ đỗ) chiếm 30% lưu lượng giao thông khu trung tâm (Shoup, 2006)','ParkConnect giảm quãng đường tìm kiếm → gián tiếp giảm phát thải CO₂']);
  addC('2.1.6','Yếu tố Pháp lý (Legal)',['Luật Doanh nghiệp 2020 (cập nhật 2025): đăng ký DN rút ngắn còn 3–5 ngày','Nghị định 13/2023/NĐ-CP về bảo vệ dữ liệu cá nhân – cần tuân thủ từ đầu','ParkConnect là trung gian – không trực tiếp chịu nghĩa vụ pháp lý bãi xe','Cần đảm bảo đối tác bãi xe tuân thủ: giấy phép, PCCC, quy hoạch']);
  addC('2.1.7','Tổng kết PESTEL',['##4 yếu tố thuận lợi quyết định:','(1) Kinh tế tăng trưởng → tầng lớp trung lưu sẵn sàng chi trả','(2) Dân số trẻ & am hiểu công nghệ → tỷ lệ adoption cao','(3) Khoảng trống cung–cầu khổng lồ → bài toán cấp thiết','(4) Hạ tầng công nghệ & đô thị thông minh → nền tảng sẵn có','Rủi ro pháp lý & công nghệ: kiểm soát được với kế hoạch tuân thủ phù hợp']);
  addC('2.2.1','Phân tích nhu cầu và hành vi khách hàng',['Maslow: nhu cầu an toàn (78% coi trọng an ninh), xã hội (65% tin đánh giá cộng đồng)','Engel, Kollat & Blackwell: 71% đang ở giai đoạn tìm kiếm rất thiếu hiệu quả','Herzberg – Động cơ: tiết kiệm thời gian (82%), minh bạch giá cả (76%), chắc chắn có chỗ','Herzberg – Duy trì: bảo mật thông tin cá nhân, độ ổn định ứng dụng','68% lo ngại "đặt chỗ rồi nhưng đến nơi bãi báo hết chỗ" – rào cản niềm tin lớn nhất']);
  addC('2.2.2','Kết quả khảo sát thị trường (346 người – 26/04 đến 05/05/2026)',['55% lái xe ≥3 lần/tuần | 65% không biết bãi nào còn trống (pain point cốt lõi)','45% chưa biết đến ứng dụng đỗ xe nào – thị trường còn nhiều dư địa','75% đánh giá bản đồ real-time hấp dẫn (≥4/5) | 72% muốn đặt & giữ chỗ trước','70% muốn cashless | 60% sẵn sàng chuyển sang ParkConnect','Mức phí chấp nhận: 10.000–15.000 VNĐ/lượt | Lo ngại lớn nhất: bảo mật thanh toán (70%)']);
  addC('2.2.3a','Phân tích đối thủ – My Parking (Viettel)',['Triển khai từ 2018: ~30 tuyến đường trung tâm, 12.000+ vị trí đỗ xe','Điểm mạnh: hậu thuẫn Viettel, thương hiệu lớn, hạ tầng viễn thông sẵn có','Điểm yếu: lỗ vận hành 2021–2024 (thâm hụt 2 tỷ), 30% giao dịch không đóng phí','Không có tính năng đặt chỗ trước – chỉ thu phí và hiển thị thông tin','Đang bị HĐND TP.HCM yêu cầu đấu thầu lại → cơ hội cho ParkConnect']);
  addC('2.2.3b','Phân tích đối thủ – iParking (VETC)',['Triển khai từ 18/04/2025: 20 tuyến đường Q1, Q5, Q10','Điểm mạnh: tận dụng hệ sinh thái ETC (4 triệu thẻ RFID), thanh toán tự động 2 lớp','Điểm yếu: chỉ thu phí, không có tìm kiếm/đặt chỗ/bản đồ/sơ đồ ô','Đòi hỏi thẻ RFID – rào cản adoption cao với người dùng mới','Kết luận: có thể hợp tác tích hợp thay vì cạnh tranh trực tiếp']);
  addC('2.2.3c','So sánh 3 nền tảng – ParkConnect vs đối thủ',['##Tính năng                          ParkConnect   My Parking   iParking','Tìm kiếm real-time                  ✓             ✗            ✗','Đặt chỗ trước + Sơ đồ ô đỗ         ✓             ✗            ✗','Đặt hộ người khác (USP độc đáo)     ✓             ✗            ✗','Phủ bãi SME tư nhân                 ✓             ✗            ✗','Dashboard phân tích cho chủ bãi     ✓             ✗            ✗','Thanh toán đa kênh (không RFID)     ✓             ✓            ✗']);
  addC('2.2.4','Phân tích Năm lực lượng cạnh tranh (Porter\'s Five Forces)',['Cạnh tranh nội bộ: THẤP – chưa có đối thủ nào xây nền tảng hai chiều hoàn chỉnh','Đối thủ mới gia nhập: TRUNG BÌNH – rào cản network effect tăng dần khi đủ quy mô','Sức mạnh nhà cung cấp (bãi xe): CAO ban đầu → giảm khi ≥50 bãi neo','Sức mạnh người mua: TRUNG BÌNH – chi phí chuyển đổi thấp giai đoạn đầu','Sản phẩm thay thế: CAO – thói quen truyền thống, Grab/Google Maps tiềm ẩn','Kết luận: Cửa sổ cơ hội rõ ràng – cần chiếm thị trường nhanh']);

